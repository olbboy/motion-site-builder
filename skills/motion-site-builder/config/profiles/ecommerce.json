{
  "meta": {
    "name": "ecommerce",
    "version": "1.0.0",
    "note": "Product-grid commerce: imagery-first, conversion-focused, quick hover/quick-view, restrained brand-accent motion, light-friendly."
  },
  "easings": {
    "ease-out": "cubic-bezier(0.23, 1, 0.32, 1)",
    "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
    "spring-pop": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  },
  "durations": {
    "micro": [0.12, 0.25],
    "entrance": [0.25, 0.5],
    "scroll_reveal": [0.3, 0.6],
    "video_crossfade": [0.4, 0.7]
  },
  "stagger": { "min": 0.04, "max": 0.08, "default": 0.05 },
  "entrance": {
    "translate_y_px": [8, 20],
    "blur_px": [0, 0],
    "note": "product cards fade + rise into the grid; keep it quick so browsing stays snappy"
  },
  "typography": {
    "display": {
      "suggested_fonts": ["Söhne", "Inter Tight", "Poppins", "Fraunces"],
      "tracking": "neutral",
      "leading": [1.0, 1.2],
      "emphasis_technique": "weight or brand-accent color; prices in tabular numbers"
    },
    "body": {
      "suggested_fonts": ["Inter", "DM Sans", "system-ui"],
      "opacity_tiers": [1, 0.7, 0.55]
    }
  },
  "palette": {
    "strategy": "brand-plus-neutral",
    "max_accent_hues": 2,
    "families": {
      "retail-light": {
        "background": ["#FFFFFF", "#FAFAFA", "#F4F4F5"],
        "foreground": "#18181B",
        "accent_examples": ["#111827", "#E11D48"]
      },
      "boutique-dark": {
        "background": ["#111111", "#1A1A1A"],
        "foreground": "#FAFAFA",
        "accent_examples": ["#D4AF37", "#F43F5E"]
      }
    }
  },
  "layering": {
    "media": 0,
    "content": 10,
    "badge": 15,
    "nav": 20,
    "cart": 30,
    "note": "product media at the base, sale/badge over media, cart drawer on top"
  },
  "radius": { "interactive": "rounded-lg", "panel": "rounded-xl", "card": "rounded-xl" },
  "dependencies": {
    "allowed": [
      "react", "react-dom", "typescript", "vite", "@vitejs/plugin-react",
      "tailwindcss", "autoprefixer", "postcss",
      "framer-motion", "motion", "lucide-react", "clsx", "tailwind-merge",
      "embla-carousel-react"
    ],
    "forbidden": ["three", "@react-three/fiber", "@react-three/drei", "gsap", "jquery"],
    "note": "embla for product carousels; avoid heavy slider plugins"
  },
  "video": {
    "required_attrs": ["autoplay", "muted", "loop", "playsinline"],
    "poster_required": true,
    "note": "product/hero video optional; poster required if used"
  },
  "interaction": {
    "press_scale": [0.96, 0.99],
    "press_duration_ms": [100, 160],
    "ui_max_duration_ms": 280,
    "ban_ease_in": true,
    "popover_origin_aware": true,
    "gate_hover_pointer_fine": true,
    "note": "quick-view + add-to-cart need crisp press feedback; card hover-lift (translateY) gated for touch"
  },
  "lint": {
    "weights": { "error": 15, "warning": 5, "info": 1 },
    "disabled_rules": [],
    "severity_overrides": {},
    "note": "brand + neutral via max_accent_hues=2"
  }
}
